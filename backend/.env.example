MONGO_URL="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/code_lens?retryWrites=true&w=majority"
DB_NAME="code_lens"

# Comma-separated origins. Use your Vercel frontend URL in production.
CORS_ORIGINS="http://localhost:3000"

# Free / student-friendly AI options:
# - Gemini free tier: create a key in Google AI Studio and set GEMINI_API_KEY
# - GitHub Models or another OpenAI-compatible provider: set OPENAI_API_KEY + OPENAI_BASE_URL
GEMINI_API_KEY=""
OPENAI_API_KEY=""
OPENAI_BASE_URL=""

# LLM config — gemini is the default free-tier friendly provider
LLM_PROVIDER="gemini"
LLM_MODEL="gemini-2.5-flash"
